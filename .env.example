# =============================================================================
# Polymarket-Kalshi Arbitrage Bot Configuration
# =============================================================================
# IMPORTANT: Copy this file to .env and fill in your actual credentials
# Never commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# KALSHI CREDENTIALS
# -----------------------------------------------------------------------------
# Your Kalshi API key ID (get from https://kalshi.com/profile/api-keys)
KALSHI_API_KEY_ID=your_kalshi_api_key_id_here

# Path to your Kalshi private key file (RSA PEM format)
# Download from Kalshi when you create API keys
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key.txt

# -----------------------------------------------------------------------------
# POLYMARKET CREDENTIALS
# -----------------------------------------------------------------------------
# Your Ethereum wallet private key (without 0x prefix)
# WARNING: Keep this extremely secure! It controls your funds!
POLY_PRIVATE_KEY=your_ethereum_private_key_here

# Your Ethereum wallet address (the funder address)
# This is the public address associated with your private key
POLY_FUNDER=0xYourWalletAddressHere

# -----------------------------------------------------------------------------
# BOT OPERATION MODE
# -----------------------------------------------------------------------------
# DRY_RUN mode (HIGHLY RECOMMENDED to start with)
# - Set to 1 or true for simulation mode (no real trades)
# - Set to 0 or false for LIVE trading (USE WITH CAUTION!)
DRY_RUN=1

# -----------------------------------------------------------------------------
# OPTIONAL: MARKET DISCOVERY
# -----------------------------------------------------------------------------
# Force market discovery refresh (ignore cache)
# Set to 1 to force fresh discovery on every startup
# FORCE_DISCOVERY=0

# -----------------------------------------------------------------------------
# OPTIONAL: TESTING & DEBUGGING
# -----------------------------------------------------------------------------
# Enable test arbitrage injection (for testing execution pipeline)
# TEST_ARB=0

# Test arbitrage type (only used if TEST_ARB=1)
# Options: poly_yes_kalshi_no, kalshi_yes_poly_no, poly_only, kalshi_only
# TEST_ARB_TYPE=poly_yes_kalshi_no

# Enable detailed price logging
# PRICE_LOGGING=0

# =============================================================================
# SETUP CHECKLIST:
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Get Kalshi API credentials from https://kalshi.com/profile/api-keys
# 3. Download your Kalshi private key file (save as kalshi_private_key.txt)
# 4. Get your Ethereum wallet private key (MetaMask, hardware wallet, etc.)
# 5. Fill in your wallet address (POLY_FUNDER)
# 6. Keep DRY_RUN=1 for initial testing!
# 7. NEVER commit .env or kalshi_private_key.txt to Git
# =============================================================================
